# Copy this file to .env.local and fill in real values. NEVER commit .env.local —
# it is gitignored. All secret keys are used ONLY in server-side API routes.

# Liveblocks (live code sync). The public key is browser-safe; the secret is not.
NEXT_PUBLIC_LIVEBLOCKS_PUBLIC_KEY=pk_dev_xxx
LIVEBLOCKS_SECRET_KEY=sk_dev_xxx

# VideoSDK.live (video/audio). Both stay server-side; the browser only ever
# receives a short-lived signed token from /api/videosdk-token.
VIDEOSDK_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
VIDEOSDK_SECRET_KEY=xxx

# Supabase. URL + anon key are browser-safe (RLS enforced). The service-role key
# BYPASSES RLS and must stay server-only (see src/features/auth/supabase/admin.ts).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Postgres connection string, used only by scripts/apply-schema.mjs to apply
# supabase/schema.sql. Not needed at runtime.
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Opt-in for the unsandboxed local code runner (app/api/run). Local dev ONLY.
# Leave unset / false anywhere that isn't your own machine. The route refuses to
# execute unless this is "true" AND NODE_ENV is not "production".
ALLOW_LOCAL_CODE_EXECUTION=false

# AI second-judge (OpenRouter). Server-side only.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Production code execution (Judge0 CE via RapidAPI). Only needed when deployed;
# local dev uses the built-in runner via ALLOW_LOCAL_CODE_EXECUTION=true.
JUDGE0_RAPIDAPI_KEY=
